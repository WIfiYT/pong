<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PONG</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: #0a0a0a;
            color: #fff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
            overflow: hidden;
        }
        
        h1 {
            margin-bottom: 15px;
            font-size: 4rem;
            letter-spacing: 15px;
            text-shadow: 0 0 20px #fff;
            font-weight: 300;
        }
        
        canvas {
            border: 4px solid #fff;
            box-shadow: 0 0 30px rgba(255, 255, 255, 0.15);
            background: #000;
            cursor: none;
        }
        
        .instructions {
            margin-top: 20px;
            font-size: 1.1rem;
            color: #aaa;
            text-align: center;
            max-width: 600px;
            line-height: 1.5;
        }
        
        .score-info {
            margin-top: 10px;
            font-size: 0.95rem;
            color: #666;
        }
    </style>
</head>
<body>
    <h1>PONG</h1>
    
    <canvas id="game" width="800" height="600"></canvas>
    
    <div class="instructions">
        <strong>Move your mouse up and down</strong> to control the left paddle.<br>
        Beat the AI opponent on the right! First to score wins the bragging rights.
    </div>
    <div class="score-info">Refresh the page to restart • Classic Pong rules</div>

    <script>
        const canvas = document.getElementById('game');
        const ctx = canvas.getContext('2d');

        // Game constants
        const WIDTH = 800;
        const HEIGHT = 600;
        const PADDLE_WIDTH = 12;
        const PADDLE_HEIGHT = 90;
        const BALL_RADIUS = 9;
        const BALL_SPEED = 3.5;
        const AI_SPEED = 3.8;

        // Game objects
        let ball = {
            x: WIDTH / 2,
            y: HEIGHT / 2,
            vx: BALL_SPEED,
            vy: 2.5
        };

        let leftPaddle = {
            x: 40,
            y: HEIGHT / 2 - PADDLE_HEIGHT / 2,
            width: PADDLE_WIDTH,
            height: PADDLE_HEIGHT
        };

        let rightPaddle = {
            x: WIDTH - 40 - PADDLE_WIDTH,
            y: HEIGHT / 2 - PADDLE_HEIGHT / 2,
            width: PADDLE_WIDTH,
            height: PADDLE_HEIGHT
        };

        let scoreLeft = 0;
        let scoreRight = 0;

        // Mouse control for left paddle
        canvas.addEventListener('mousemove', (e) => {
            const rect = canvas.getBoundingClientRect();
            const mouseY = e.clientY - rect.top;
            
            // Center paddle on mouse
            leftPaddle.y = mouseY - leftPaddle.height / 2;
            
            // Clamp to canvas bounds
            if (leftPaddle.y < 0) leftPaddle.y = 0;
            if (leftPaddle.y + leftPaddle.height > HEIGHT) {
                leftPaddle.y = HEIGHT - leftPaddle.height;
            }
        });

        // Reset ball to center with random direction
        function resetBall() {
            ball.x = WIDTH / 2;
            ball.y = HEIGHT / 2;
            
            // Random horizontal direction
            const direction = Math.random() > 0.5 ? 1 : -1;
            ball.vx = direction * BALL_SPEED;
            
            // Random vertical angle (avoid too flat)
            ball.vy = (Math.random() * 3.2 + 1) * (Math.random() > 0.5 ? 1 : -1);
        }

        // Simple AI for right paddle
        function updateAI() {
            const paddleCenter = rightPaddle.y + rightPaddle.height / 2;
            const targetY = ball.y;
            
            if (paddleCenter < targetY - 10) {
                rightPaddle.y += AI_SPEED;
            } else if (paddleCenter > targetY + 10) {
                rightPaddle.y -= AI_SPEED;
            }
            
            // Clamp AI paddle
            if (rightPaddle.y < 0) rightPaddle.y = 0;
            if (rightPaddle.y + rightPaddle.height > HEIGHT) {
                rightPaddle.y = HEIGHT - rightPaddle.height;
            }
        }

        // Update game state
        function update() {
            // Move ball
            ball.x += ball.vx;
            ball.y += ball.vy;

            // Bounce off top and bottom walls
            if (ball.y - BALL_RADIUS < 0 || ball.y + BALL_RADIUS > HEIGHT) {
                ball.vy = -ball.vy;
                // Keep ball inside bounds
                if (ball.y - BALL_RADIUS < 0) ball.y = BALL_RADIUS;
                if (ball.y + BALL_RADIUS > HEIGHT) ball.y = HEIGHT - BALL_RADIUS;
            }

            // Left wall - right player scores
            if (ball.x - BALL_RADIUS < 0) {
                scoreRight++;
                resetBall();
            }

            // Right wall - left player scores
            if (ball.x + BALL_RADIUS > WIDTH) {
                scoreLeft++;
                resetBall();
            }

            // Left paddle collision
            if (ball.vx < 0 &&
                ball.x - BALL_RADIUS < leftPaddle.x + leftPaddle.width &&
                ball.x + BALL_RADIUS > leftPaddle.x &&
                ball.y - BALL_RADIUS < leftPaddle.y + leftPaddle.height &&
                ball.y + BALL_RADIUS > leftPaddle.y) {
                
                ball.vx = -ball.vx;
                
                // Add angle based on where ball hit the paddle
                const hitPoint = (ball.y - (leftPaddle.y + leftPaddle.height / 2)) / (leftPaddle.height / 2);
                ball.vy = hitPoint * 3.5;
            }

            // Right paddle collision
            if (ball.vx > 0 &&
                ball.x + BALL_RADIUS > rightPaddle.x &&
                ball.x - BALL_RADIUS < rightPaddle.x + rightPaddle.width &&
                ball.y - BALL_RADIUS < rightPaddle.y + rightPaddle.height &&
                ball.y + BALL_RADIUS > rightPaddle.y) {
                
                ball.vx = -ball.vx;
                
                // Add angle based on where ball hit the paddle
                const hitPoint = (ball.y - (rightPaddle.y + rightPaddle.height / 2)) / (rightPaddle.height / 2);
                ball.vy = hitPoint * 3.5;
            }

            // Update AI
            updateAI();
        }

        // Draw everything
        function draw() {
            // Clear with black background
            ctx.fillStyle = '#000';
            ctx.fillRect(0, 0, WIDTH, HEIGHT);

            // Draw center dashed line (net)
            ctx.strokeStyle = '#fff';
            ctx.lineWidth = 3;
            ctx.setLineDash([15, 15]);
            ctx.beginPath();
            ctx.moveTo(WIDTH / 2, 0);
            ctx.lineTo(WIDTH / 2, HEIGHT);
            ctx.stroke();
            ctx.setLineDash([]);

            // Draw scores
            ctx.fillStyle = '#fff';
            ctx.font = 'bold 72px Segoe UI, Arial';
            ctx.textAlign = 'center';
            ctx.fillText(scoreLeft, WIDTH / 4, 90);
            ctx.fillText(scoreRight, (3 * WIDTH) / 4, 90);

            // Draw left paddle
            ctx.fillStyle = '#fff';
            ctx.fillRect(leftPaddle.x, leftPaddle.y, leftPaddle.width, leftPaddle.height);

            // Draw right paddle
            ctx.fillRect(rightPaddle.x, rightPaddle.y, rightPaddle.width, rightPaddle.height);

            // Draw ball
            ctx.beginPath();
            ctx.arc(ball.x, ball.y, BALL_RADIUS, 0, Math.PI * 2);
            ctx.fill();
        }

        // Main game loop
        function gameLoop() {
            update();
            draw();
            requestAnimationFrame(gameLoop);
        }

        // Initialize and start game
        function init() {
            resetBall();
            gameLoop();
        }

        // Start the game when page loads
        window.onload = init;
    </script>
</body>
</html>
